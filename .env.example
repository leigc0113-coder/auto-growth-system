# ==========================================
# Auto Growth System - 完整环境变量配置
# ==========================================

# ==========================================
# 1. Telegram Bot 配置（多账号轮换防封）
# ==========================================

# 主机器人 Token（用于系统通知、管理员命令）
# 获取方式：@BotFather -> /newbot -> 复制 Token
TELEGRAM_BOT_TOKEN_1=7961354841:AAG8kmlSNMHARF4FPcMw5ZqkT9ym3-UDLOs

# 备用机器人 Token（用于推广任务，轮换使用）
# 作用：防止单一账号被限流或封禁
TELEGRAM_BOT_TOKEN_2=8727846472:AAF04lUNyyrVpXN-SKY0kjfH8uxoLNxk_4M

# 系统使用的主 Token（二选一，推荐用第一个）
TELEGRAM_BOT_TOKEN=7961354841:AAG8kmlSNMHARF4FPcMw5ZqkT9ym3-UDLOs

# ==========================================
# 2. AI 内容生成配置（Kimi/Moonshot）
# ==========================================

# Kimi API Key（用于生成推广文案、回复模板）
# 获取方式：https://platform.moonshot.cn/ -> API Keys
KIMI_API_KEY=sk-cKbQUlgUqkptHFQ5SIR3z40cIox2qeqDmWApgr4fsPsGqe1f

# Kimi API 端点
KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions

# 使用的模型（8k/32k/128k 根据内容长度选择）
KIMI_MODEL=moonshot-v1-8k

# ==========================================
# 3. 数据库配置（MongoDB）
# ==========================================

# MongoDB 连接字符串
# 本地安装：mongodb://localhost:27017/auto_growth
# 远程/Atlas：mongodb+srv://user:pass@cluster.mongodb.net/auto_growth
MONGODB_URI=mongodb://localhost:27017/auto_growth

# ==========================================
# 4. 代理配置（IPRoyal 住宅IP）
# ==========================================

# 是否启用代理（true/false）
PROXY_ENABLED=true

# 代理服务器地址（Puppeteer 使用）
# 格式：http://用户名:密码@服务器:端口
PROXY_URL=http://3L3TODmeB74X7FGC:530tn4b8HeBfG2Rh_country-in_city-bacheli_session-Z7nqzlfG_lifetime-30m@geo.iproyal.com:12321

# 代理拆分配置（某些模块需要单独配置）
PROXY_SERVER=http://geo.iproyal.com:12321
PROXY_USERNAME=3L3TODmeB74X7FGC
PROXY_PASSWORD=530tn4b8HeBfG2Rh_country-in_city-bacheli_session-Z7nqzlfG_lifetime-30m

# ==========================================
# 5. 管理员配置（系统通知+人工审核）
# ==========================================

# 管理员 Telegram ID（数字ID，不是用户名）
# 获取方式：@userinfobot -> 发送任意消息 -> 查看 id 字段
ADMIN_TELEGRAM_ID=5234313912

# 兼容旧配置格式
ADMIN_IDS=["5234313912"]

# 管理员用户名（用于日志记录）
ADMIN_USERNAME=@Winbiginsta

# ==========================================
# 6. 推广目标配置（频道+群组）
# ==========================================

# 目标频道（公开频道，用于内容推广）
# 作用：系统采集的用户会被引导关注此频道
CHANNEL_ID=-1002683944820
CHANNEL_USERNAME=@TeenpattiMastetClub

# 目标群组（公开群组，用于用户沉淀）
# 作用：活跃用户会被邀请加入此群组
GROUP_ID=-1002584745356
GROUP_USERNAME=@WinBigInstaOfficial

# ==========================================
# 7. 采集配置（关键词+平台）
# ==========================================

# 采集关键词（JSON 数组，系统自动轮换搜索）
SEARCH_KEYWORDS=["teen patti","online earning","make money india","lottery india","rummy","cash games"]

# 采集平台开关（true=启用，false=禁用）
SCRAPE_TELEGRAM_CHANNELS=true
SCRAPE_TELEGRAM_GROUPS=true
SCRAPE_REDDIT=false
SCRAPE_TELEGRAM_GROUPS=true

# ==========================================
# 8. 推广配置（自动化 outreach）
# ==========================================

# 每日最大推广数量（防止触发平台限制）
MAX_DAILY_OUTREACH=50

# 推广间隔时间（毫秒，模拟真人行为）
OUTREACH_INTERVAL_MIN=30000    # 30秒
OUTREACH_INTERVAL_MAX=120000   # 2分钟

# 推广文案模板（可选，留空则使用 AI 生成）
# OUTREACH_TEMPLATE="Hi! Check out our Teen Patti channel for daily tips and giveaways!"

# ==========================================
# 9. 系统配置
# ==========================================

# 运行环境（development/production）
NODE_ENV=production

# 日志级别（error/warn/info/debug）
LOG_LEVEL=info

# 时区设置（印度标准时间）
TIMEZONE=Asia/Kolkata

# 数据导出目录（采集结果保存路径）
EXPORT_DIR=/opt/auto-growth-system/data

# ==========================================
# 10. 定时任务配置（Cron 表达式）
# ==========================================

# 采集任务运行时间（每天凌晨 2 点）
SCHEDULE_SCRAPER=0 2 * * *

# 推广任务运行时间（每天上午 10 点）
SCHEDULE_OUTREACH=0 10 * * *

# 数据报告生成时间（每天下午 6 点）
SCHEDULE_REPORT=0 18 * * *
