# 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============================================
# Telegram Bot Tokens (推广用小号)
# 建议至少 3 个，用于轮换防封号
# ============================================
TELEGRAM_BOT_TOKEN_1=your_first_bot_token_here
TELEGRAM_BOT_TOKEN_2=your_second_bot_token_here
TELEGRAM_BOT_TOKEN_3=your_third_bot_token_here

# ============================================
# AI Content Generation (Kimi API)
# 从 https://platform.moonshot.cn/ 获取
# ============================================
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_MODEL=moonshot-v1-8k

# ============================================
# Reddit API (可选)
# 从 https://www.reddit.com/prefs/apps 创建应用
# ============================================
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ============================================
# Proxy Configuration (固定IP)
# 如果有代理服务器，填写以下信息
# ============================================
PROXY_ENABLED=false
PROXY_SERVER=http://your-proxy-server:port
PROXY_USERNAME=your_username
PROXY_PASSWORD=your_password

# ============================================
# Database (MongoDB)
# ============================================
MONGODB_URI=mongodb://localhost:27017/auto_growth
# 或 MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/auto_growth

# ============================================
# Admin Configuration
# ============================================
ADMIN_TELEGRAM_ID=your_admin_telegram_id
ADMIN_USERNAME=@your_username

# ============================================
# System Configuration
# ============================================
NODE_ENV=development
LOG_LEVEL=info
TIMEZONE=Asia/Kolkata
